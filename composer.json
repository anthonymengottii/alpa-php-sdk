{
    "name": "alpa/alpa-php",
    "version": "2.0.0",
    "description": "SDK oficial da Alpa para PHP - Integração fácil com a API de pagamentos",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Alpa",
            "email": "suporte@usealpa.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Alpa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Alpa\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "support": {
        "issues": "https://github.com/anthonymengottii/alpa-php-sdk/issues",
        "source": "https://github.com/anthonymengottii/alpa-php-sdk",
        "docs": "https://docs.usealpa.com"
    }
}
